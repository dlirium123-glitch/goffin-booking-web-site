rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }

    function isValidSlotId(slotId) {
      return slotId is string && slotId.matches('^[0-9]{8}_[0-9]{4}$');
    }

    function isValidRequestId(value) {
      return value is string && value.size() >= 10 && value.size() <= 120;
    }

    function isAtLeast48hInFuture(ts) {
      return ts is timestamp && ts >= request.time + duration.value(48, 'h');
    }

    function publicSlotIsFree(slotId) {
      return exists(/databases/$(database)/documents/publicSlots/$(slotId))
        && get(/databases/$(database)/documents/publicSlots/$(slotId)).data.status == "free";
    }

    function doesNotExist(path) {
      return !exists(path);
    }

    function slotListHasValidShape(slotIds) {
      return slotIds is list
        && slotIds.size() >= 1
        && slotIds.size() <= 6
        && (
          (slotIds.size() == 1 && isValidSlotId(slotIds[0])) ||
          (slotIds.size() == 2 && isValidSlotId(slotIds[0]) && isValidSlotId(slotIds[1])) ||
          (slotIds.size() == 3 && isValidSlotId(slotIds[0]) && isValidSlotId(slotIds[1]) && isValidSlotId(slotIds[2])) ||
          (slotIds.size() == 4 && isValidSlotId(slotIds[0]) && isValidSlotId(slotIds[1]) && isValidSlotId(slotIds[2]) && isValidSlotId(slotIds[3])) ||
          (slotIds.size() == 5 && isValidSlotId(slotIds[0]) && isValidSlotId(slotIds[1]) && isValidSlotId(slotIds[2]) && isValidSlotId(slotIds[3]) && isValidSlotId(slotIds[4])) ||
          (slotIds.size() == 6 && isValidSlotId(slotIds[0]) && isValidSlotId(slotIds[1]) && isValidSlotId(slotIds[2]) && isValidSlotId(slotIds[3]) && isValidSlotId(slotIds[4]) && isValidSlotId(slotIds[5]))
        );
    }

    function slotListAllPublicFree(slotIds) {
      return slotListHasValidShape(slotIds)
        && (
          (slotIds.size() == 1 && publicSlotIsFree(slotIds[0])) ||
          (slotIds.size() == 2 && publicSlotIsFree(slotIds[0]) && publicSlotIsFree(slotIds[1])) ||
          (slotIds.size() == 3 && publicSlotIsFree(slotIds[0]) && publicSlotIsFree(slotIds[1]) && publicSlotIsFree(slotIds[2])) ||
          (slotIds.size() == 4 && publicSlotIsFree(slotIds[0]) && publicSlotIsFree(slotIds[1]) && publicSlotIsFree(slotIds[2]) && publicSlotIsFree(slotIds[3])) ||
          (slotIds.size() == 5 && publicSlotIsFree(slotIds[0]) && publicSlotIsFree(slotIds[1]) && publicSlotIsFree(slotIds[2]) && publicSlotIsFree(slotIds[3]) && publicSlotIsFree(slotIds[4])) ||
          (slotIds.size() == 6 && publicSlotIsFree(slotIds[0]) && publicSlotIsFree(slotIds[1]) && publicSlotIsFree(slotIds[2]) && publicSlotIsFree(slotIds[3]) && publicSlotIsFree(slotIds[4]) && publicSlotIsFree(slotIds[5]))
        );
    }

    function holdOwnedByUser(holdId) {
      return exists(/databases/$(database)/documents/holds/$(holdId))
        && get(/databases/$(database)/documents/holds/$(holdId)).data.uid == uid();
    }

    function holdSlotMatches(slotId, holdId) {
      return exists(/databases/$(database)/documents/holdSlots/$(slotId))
        && get(/databases/$(database)/documents/holdSlots/$(slotId)).data.holdId == holdId
        && get(/databases/$(database)/documents/holdSlots/$(slotId)).data.status == "hold"
        && get(/databases/$(database)/documents/holdSlots/$(slotId)).data.expiresAt > request.time;
    }

    function allSlotsHeldByHold(slotIds, holdId) {
      return slotListHasValidShape(slotIds)
        && holdOwnedByUser(holdId)
        && (
          (slotIds.size() == 1 && holdSlotMatches(slotIds[0], holdId)) ||
          (slotIds.size() == 2 && holdSlotMatches(slotIds[0], holdId) && holdSlotMatches(slotIds[1], holdId)) ||
          (slotIds.size() == 3 && holdSlotMatches(slotIds[0], holdId) && holdSlotMatches(slotIds[1], holdId) && holdSlotMatches(slotIds[2], holdId)) ||
          (slotIds.size() == 4 && holdSlotMatches(slotIds[0], holdId) && holdSlotMatches(slotIds[1], holdId) && holdSlotMatches(slotIds[2], holdId) && holdSlotMatches(slotIds[3], holdId)) ||
          (slotIds.size() == 5 && holdSlotMatches(slotIds[0], holdId) && holdSlotMatches(slotIds[1], holdId) && holdSlotMatches(slotIds[2], holdId) && holdSlotMatches(slotIds[3], holdId) && holdSlotMatches(slotIds[4], holdId)) ||
          (slotIds.size() == 6 && holdSlotMatches(slotIds[0], holdId) && holdSlotMatches(slotIds[1], holdId) && holdSlotMatches(slotIds[2], holdId) && holdSlotMatches(slotIds[3], holdId) && holdSlotMatches(slotIds[4], holdId) && holdSlotMatches(slotIds[5], holdId))
        );
    }

    function userKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "email", "company", "vat", "phone", "hqAddress",
        "billingAddress", "contactName", "createdAt", "updatedAt"
      ]);
    }

    function holdKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "uid", "requestAddressTempKey", "slotIds", "start", "end",
        "expiresAt", "status", "createdAt", "updatedAt"
      ]);
    }

    function holdSlotKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "holdId", "start", "end", "expiresAt", "status", "createdAt", "updatedAt"
      ]);
    }

    function bookingKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "slotId", "appointmentId", "requestId", "holdId", "status",
        "start", "end", "createdAt", "updatedAt"
      ]);
    }

    function requestKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "requestNumber", "uid", "status", "customerSnapshot",
        "totalAddresses", "totalAppointments", "notes",
        "createdAt", "updatedAt"
      ]);
    }

    function requestAddressKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "requestId", "uid", "label", "addressLine1", "addressLine2",
        "postalCode", "city", "region", "country", "warningFlags",
        "status", "selectedAppointmentId", "serviceMinutes",
        "travelMinutes", "totalDurationMinutes", "createdAt", "updatedAt"
      ]);
    }

    function requestServiceKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "requestId", "requestAddressId", "uid", "serviceTypeId",
        "serviceCodeSnapshot", "serviceLabelSnapshot", "installationsCount",
        "serviceMinutes", "answers", "createdAt", "updatedAt"
      ]);
    }

    function appointmentKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "requestId", "requestAddressId", "uid", "status", "slotIds", "holdId",
        "start", "end", "serviceMinutes", "travelMinutes", "totalDurationMinutes",
        "officeEmailStatus", "outlookStatus", "outlookReference",
        "createdAt", "updatedAt"
      ]);
    }

    function outboxKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        "type", "status", "to", "subject", "requestId", "uid",
        "payload", "attempts", "lastAttemptAt", "sentAt", "error",
        "createdAt", "updatedAt"
      ]);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && userId == uid();
      allow list: if false;
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && userId == uid()
        && userKeysAllowed()
        && request.resource.data.email is string
        && request.resource.data.company is string
        && request.resource.data.vat is string
        && request.resource.data.phone is string
        && request.resource.data.hqAddress is string
        && request.resource.data.billingAddress is string
        && request.resource.data.contactName is string;
      allow delete: if isAdmin();
    }

    match /serviceTypes/{serviceTypeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /publicSlots/{slotId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /freeSlots/{slotId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /holds/{holdId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
      allow create, update: if isSignedIn()
        && holdKeysAllowed()
        && request.resource.data.uid == uid()
        && request.resource.data.requestAddressTempKey is string
        && slotListHasValidShape(request.resource.data.slotIds)
        && slotListAllPublicFree(request.resource.data.slotIds)
        && request.resource.data.start is timestamp
        && request.resource.data.end is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt <= request.time + duration.value(30, 'm')
        && isAtLeast48hInFuture(request.resource.data.start)
        && request.resource.data.status == "hold"
        && (request.method == "create" ? doesNotExist(/databases/$(database)/documents/holds/$(holdId)) : resource.data.uid == uid());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
    }

    match /holdSlots/{slotId} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && isValidSlotId(slotId)
        && holdSlotKeysAllowed()
        && request.resource.data.holdId is string
        && holdOwnedByUser(request.resource.data.holdId)
        && request.resource.data.start is timestamp
        && request.resource.data.end is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.status == "hold"
        && publicSlotIsFree(slotId);
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.holdId is string && holdOwnedByUser(resource.data.holdId));
    }

    match /bookings/{slotId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isValidSlotId(slotId)
        && bookingKeysAllowed()
        && doesNotExist(/databases/$(database)/documents/bookings/$(slotId))
        && request.resource.data.slotId == slotId
        && request.resource.data.appointmentId is string
        && request.resource.data.requestId is string
        && request.resource.data.holdId is string
        && request.resource.data.status == "pending"
        && request.resource.data.start is timestamp
        && request.resource.data.end is timestamp
        && isAtLeast48hInFuture(request.resource.data.start)
        && holdSlotMatches(slotId, request.resource.data.holdId);
      allow update, delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
      allow create: if isSignedIn()
        && isValidRequestId(requestId)
        && requestKeysAllowed()
        && doesNotExist(/databases/$(database)/documents/requests/$(requestId))
        && request.resource.data.uid == uid()
        && request.resource.data.requestNumber is string
        && request.resource.data.status == "pending"
        && request.resource.data.customerSnapshot is map
        && request.resource.data.totalAddresses is int
        && request.resource.data.totalAppointments is int
        && request.resource.data.totalAddresses >= 1
        && request.resource.data.totalAppointments >= 1;
      allow update, delete: if isAdmin();
    }

    match /requestAddresses/{requestAddressId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
      allow create: if isSignedIn()
        && requestAddressKeysAllowed()
        && request.resource.data.uid == uid()
        && request.resource.data.requestId is string
        && request.resource.data.addressLine1 is string
        && request.resource.data.postalCode is string
        && request.resource.data.city is string
        && request.resource.data.region is string
        && request.resource.data.country is string
        && request.resource.data.warningFlags is list
        && request.resource.data.status == "pending"
        && request.resource.data.selectedAppointmentId is string
        && request.resource.data.serviceMinutes is int
        && request.resource.data.travelMinutes is int
        && request.resource.data.totalDurationMinutes is int
        && request.resource.data.totalDurationMinutes == request.resource.data.serviceMinutes + request.resource.data.travelMinutes;
      allow update, delete: if isAdmin();
    }

    match /requestServices/{requestServiceId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
      allow create: if isSignedIn()
        && requestServiceKeysAllowed()
        && request.resource.data.uid == uid()
        && request.resource.data.requestId is string
        && request.resource.data.requestAddressId is string
        && request.resource.data.serviceTypeId is string
        && request.resource.data.serviceCodeSnapshot is string
        && request.resource.data.serviceLabelSnapshot is string
        && request.resource.data.installationsCount is int
        && request.resource.data.installationsCount >= 1
        && request.resource.data.serviceMinutes is int
        && request.resource.data.serviceMinutes >= 60
        && request.resource.data.answers is map;
      allow update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
      allow create: if isSignedIn()
        && appointmentKeysAllowed()
        && request.resource.data.uid == uid()
        && request.resource.data.requestId is string
        && request.resource.data.requestAddressId is string
        && request.resource.data.status == "pending"
        && slotListHasValidShape(request.resource.data.slotIds)
        && request.resource.data.holdId is string
        && allSlotsHeldByHold(request.resource.data.slotIds, request.resource.data.holdId)
        && request.resource.data.start is timestamp
        && request.resource.data.end is timestamp
        && isAtLeast48hInFuture(request.resource.data.start)
        && request.resource.data.serviceMinutes is int
        && request.resource.data.travelMinutes is int
        && request.resource.data.totalDurationMinutes is int
        && request.resource.data.totalDurationMinutes == request.resource.data.serviceMinutes + request.resource.data.travelMinutes
        && request.resource.data.officeEmailStatus == "pending"
        && request.resource.data.outlookStatus == "not_created";
      allow update, delete: if isAdmin();
    }

    match /outbox/{messageId} {
      allow read, update, delete: if isAdmin();
      allow create: if isSignedIn()
        && outboxKeysAllowed()
        && request.resource.data.uid == uid()
        && request.resource.data.type == "new_request"
        && request.resource.data.status == "pending"
        && request.resource.data.to is string
        && request.resource.data.subject is string
        && request.resource.data.requestId is string
        && request.resource.data.payload is map
        && request.resource.data.attempts == 0;
    }

    match /modificationRequests/{docId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == uid());
      allow create: if isSignedIn()
        && request.resource.data.uid == uid()
        && request.resource.data.createdAt is timestamp
        && request.resource.data.status is string;
      allow update, delete: if isAdmin();
    }

    match /slots/{docId} { allow read, write: if isAdmin(); }
    match /syncHealth/{docId} { allow read, write: if isAdmin(); }
    match /settings/{docId} { allow read, write: if isAdmin(); }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
